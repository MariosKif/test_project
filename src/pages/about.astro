---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ProcessTimeline from '../components/ProcessTimeline.astro';
import CTASection from '../components/CTASection.astro';
import ValuesGrid from '../components/ValuesGrid.astro';

---

<BaseLayout
  title="Σχετικά — 210Designs"
  description="Μάθετε για την 210Designs, την ιστορία, τις αξίες και την ομάδα πίσω από τη δημιουργία."
>
  <PageHero
    title="Σχετικά με Εμάς"
    subtitle="Η ιστορία, οι αξίες και οι άνθρωποι πίσω από την 210Designs."
    gradient={true}
    breadcrumbs={[
      { label: 'Αρχική', href: '/' },
      { label: 'Σχετικά', href: '/about' },
    ]}
  />

  <!-- Our Story Section -->
  <section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Text side -->
        <div class="gs-reveal-left">
          <h2 class="font-display text-3xl md:text-4xl font-bold text-neutral-900 mb-8">
            Δημιουργούμε <span class="gradient-text">ψηφιακές εμπειρίες</span> που συγκινούν
          </h2>
          <p class="text-lg leading-relaxed text-neutral-600 mb-6">
            Η 210Designs ξεκίνησε το 2023 με μια απλή ιδέα: κάθε επιχείρηση, μικρή ή μεγάλη, αξίζει μια ιστοσελίδα που πραγματικά της μοιάζει. Από την πρώτη μέρα, βάζουμε τον πελάτη στο κέντρο — ακούμε, καταλαβαίνουμε και δημιουργούμε <span class="gradient-text font-semibold">μαζί</span>.
          </p>
          <p class="text-lg leading-relaxed text-neutral-600">
            Δεν μας ενδιαφέρει απλά να φτιάξουμε κάτι ωραίο. Θέλουμε να φτιάξουμε κάτι που <span class="gradient-text font-semibold">δουλεύει</span> — που φέρνει πελάτες, χτίζει εμπιστοσύνη και κάνει τη δουλειά σας πιο εύκολη. Κάθε project για εμάς είναι μια συνεργασία, όχι απλά μια παραγγελία.
          </p>
        </div>

        <!-- Image side -->
        <div class="gs-reveal-right">
          <div class="image-hover rounded-2xl">
            <img
              src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=800&q=80"
              alt="Ομάδα που συνεργάζεται"
              class="w-full h-auto rounded-2xl object-cover aspect-4/3"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <ValuesGrid />

  <!-- Process Section -->
  <section class="relative overflow-hidden gradient-bg">
    <div class="blob blob-purple -top-40 right-0 opacity-20"></div>
    <div class="blob blob-orange -bottom-40 left-0 opacity-15"></div>

    <div class="relative max-w-7xl mx-auto px-6">
      <div class="text-center pt-20 md:pt-28">
        <h2 class="gs-reveal font-display text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
          Η <span class="gradient-text">Διαδικασία</span> μας
        </h2>
        <p class="gs-reveal text-lg text-neutral-500 max-w-2xl mx-auto">
          Μια δοκιμασμένη ροή εργασίας που μετατρέπει το όραμά σας σε πραγματικότητα
        </p>
      </div>
    </div>
    <ProcessTimeline />
  </section>

  <!-- CTA Section -->
  <CTASection heading="Έτοιμοι να Ξεκινήσετε το Project σας;" />

</BaseLayout>
