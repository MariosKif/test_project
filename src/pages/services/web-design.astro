---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTASection from '../../components/CTASection.astro';

const features = [
  {
    title: "Προσαρμοσμένος Σχεδιασμός UI/UX",
    description: "Κάθε σχεδιασμός δημιουργείται από το μηδέν, προσαρμοσμένος στο brand και τους στόχους σας.",
  },
  {
    title: "Responsive Διατάξεις",
    description: "Τέλεια εμφάνιση σε κάθε συσκευή — desktop, tablet και κινητό.",
  },
  {
    title: "Διαδραστικά Prototypes",
    description: "Δείτε και δοκιμάστε τον σχεδιασμό σας πριν την ανάπτυξη με διαδραστικά mockups.",
  },
  {
    title: "Δημιουργία Design System",
    description: "Ένα ολοκληρωμένο σύστημα σχεδιασμού που εξασφαλίζει συνέπεια σε όλη την ιστοσελίδα σας.",
  },
  {
    title: "Έρευνα Χρηστών & Testing",
    description: "Αποφάσεις βασισμένες σε δεδομένα χρηστών για βέλτιστη εμπειρία χρήσης.",
  },
];
---

<BaseLayout title="Web Design | 210Designs" description="Δημιουργούμε εντυπωσιακούς, ανθρωποκεντρικούς σχεδιασμούς που μαγεύουν το κοινό σας.">
  <PageHero
    title="Web Design"
    subtitle="Εντυπωσιακοί σχεδιασμοί που μαγεύουν το κοινό σας και αυξάνουν τις μετατροπές"
    gradient={true}
  />

  <section class="py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-20">
        <div class="gs-reveal-left">
          <h2 class="font-display text-3xl md:text-4xl font-bold text-neutral-900 mb-6">
            Σχεδιασμός που <span class="gradient-text">ξεχωρίζει</span>
          </h2>
          <p class="text-lg text-neutral-600 leading-relaxed mb-6">
            Δημιουργούμε εντυπωσιακούς, ανθρωποκεντρικούς σχεδιασμούς που μαγεύουν το κοινό σας και αυξάνουν την αλληλεπίδραση. Κάθε pixel έχει σκοπό, κάθε αλληλεπίδραση είναι μελετημένη.
          </p>
          <p class="text-lg text-neutral-600 leading-relaxed">
            Από μινιμαλιστικά landing pages μέχρι πολύπλοκες web εφαρμογές, ο σχεδιασμός μας συνδυάζει αισθητική αριστεία με λειτουργικότητα.
          </p>
        </div>
        <div class="gs-reveal-right">
          <div class="image-hover rounded-2xl">
            <img
              src="https://images.unsplash.com/photo-1561070791-2526d30994b5?w=800&q=80"
              alt="Web Design"
              class="w-full h-auto rounded-2xl object-cover aspect-video"
              loading="lazy"
            />
          </div>
        </div>
      </div>

      <div class="gs-stagger grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {features.map((feature) => (
          <div class="gs-reveal rounded-2xl border border-neutral-200 p-6 hover:border-primary-300 hover:shadow-lg transition-all duration-300">
            <h3 class="font-semibold text-neutral-900 mb-2">{feature.title}</h3>
            <p class="text-sm text-neutral-500 leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection heading="Θέλετε έναν σχεδιασμό που ξεχωρίζει;" />
</BaseLayout>
