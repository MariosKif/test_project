---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTASection from '../../components/CTASection.astro';

const features = [
  {
    title: "Στρατηγική Brand",
    description: "Ορίζουμε την ταυτότητα, τις αξίες και τη φωνή του brand σας για να ξεχωρίσετε στην αγορά.",
  },
  {
    title: "Λογότυπο & Οπτική Ταυτότητα",
    description: "Σχεδιασμός λογοτύπου και πλήρους οπτικής ταυτότητας που αντικατοπτρίζει την ουσία σας.",
  },
  {
    title: "Οδηγίες Brand",
    description: "Ολοκληρωμένο brand book με κανόνες χρήσης χρωμάτων, γραμματοσειρών και στοιχείων.",
  },
  {
    title: "Υλικό Marketing",
    description: "Σχεδιασμός επαγγελματικών καρτών, brochures, social media templates και πολλά ακόμα.",
  },
  {
    title: "Motion Graphics",
    description: "Animations και video content που ζωντανεύουν το brand σας στο digital χώρο.",
  },
  {
    title: "Social Media Branding",
    description: "Ενιαία οπτική παρουσία σε όλα τα κοινωνικά δίκτυα με templates, covers και stories.",
  },
];
---

<BaseLayout title="Branding | 210Designs" description="Δημιουργούμε συναρπαστικές ταυτότητες brand που αφηγούνται την ιστορία σας.">
  <PageHero
    title="Branding"
    subtitle="Συναρπαστικές ταυτότητες brand που αφηγούνται την ιστορία σας"
    gradient={true}
  />

  <section class="py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-20">
        <div class="gs-reveal-left">
          <h2 class="font-display text-3xl md:text-4xl font-bold text-neutral-900 mb-6">
            Brand που <span class="gradient-text">εμπνέει</span>
          </h2>
          <p class="text-lg text-neutral-600 leading-relaxed mb-6">
            Δημιουργούμε συναρπαστικές ταυτότητες brand που αφηγούνται την ιστορία σας και συνδέονται με το κοινό σας. Από τη στρατηγική μέχρι την υλοποίηση.
          </p>
          <p class="text-lg text-neutral-600 leading-relaxed">
            Κάθε brand έχει μια μοναδική ιστορία. Εμείς τη μετατρέπουμε σε οπτική γλώσσα που μιλάει στους πελάτες σας.
          </p>
        </div>
        <div class="gs-reveal-right">
          <div class="image-hover rounded-2xl">
            <img
              src="https://images.unsplash.com/photo-1558655146-9f40138edfeb?w=800&q=80"
              alt="Branding"
              class="w-full h-auto rounded-2xl object-cover aspect-video"
              loading="lazy"
            />
          </div>
        </div>
      </div>

      <div class="gs-stagger grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {features.map((feature) => (
          <div class="gs-reveal rounded-2xl border border-neutral-200 p-6 hover:border-primary-300 hover:shadow-lg transition-all duration-300">
            <h3 class="font-semibold text-neutral-900 mb-2">{feature.title}</h3>
            <p class="text-sm text-neutral-500 leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection heading="Θέλετε ένα brand που ξεχωρίζει;" />
</BaseLayout>
