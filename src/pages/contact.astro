---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
---

<BaseLayout
  title="Επικοινωνία | 210Designs"
  description="Έτοιμοι να ξεκινήσετε το project σας; Επικοινωνήστε με την ομάδα 210Designs."
>

  <!-- Contact Section -->
  <section class="py-20 md:py-28 relative overflow-hidden">
    <div class="blob blob-purple -top-60 -right-40 opacity-10"></div>
    <div class="blob blob-blue -bottom-60 -left-40 opacity-10"></div>

    <div class="relative max-w-6xl mx-auto px-6">
      <!-- Section Header -->
      <div class="text-center mb-14">
        <h2 class="gs-reveal font-display text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
          Ας Ξεκινήσουμε μια <span class="gradient-text">Συζήτηση</span>
        </h2>
        <p class="gs-reveal text-lg text-neutral-500 max-w-2xl mx-auto">
          Συμπληρώστε τη φόρμα παρακάτω και θα επικοινωνήσουμε μαζί σας εντός 24 ωρών.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10">

        <!-- Left Column — Contact Info (narrower) -->
        <div class="lg:col-span-2 gs-reveal">
          <div class="bg-gradient-to-br from-purple-700 via-violet-700 to-purple-900 rounded-2xl p-8 md:p-10 h-full flex flex-col justify-between">
            <div>
              <h3 class="font-display text-xl font-bold text-white mb-2">
                Στοιχεία Επικοινωνίας
              </h3>
              <p class="text-purple-200 text-sm mb-8">Επικοινωνήστε μέσω οποιουδήποτε από αυτά τα κανάλια.</p>

              <div class="space-y-6">
                <!-- Email -->
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-lg bg-white/10 flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-purple-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-xs font-medium text-purple-300 uppercase tracking-wider">Email</p>
                    <a href="mailto:hello@210designs.com" class="text-white hover:text-purple-200 transition-colors duration-200 text-sm">hello@210designs.com</a>
                  </div>
                </div>

                <!-- Phone -->
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-lg bg-white/10 flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-purple-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-xs font-medium text-purple-300 uppercase tracking-wider">Τηλέφωνο</p>
                    <a href="tel:+15552100210" class="text-white hover:text-purple-200 transition-colors duration-200 text-sm">+1 (555) 210-0210</a>
                  </div>
                </div>

                <!-- Office Hours -->
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-lg bg-white/10 flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-purple-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-xs font-medium text-purple-300 uppercase tracking-wider">Ώρες Λειτουργίας</p>
                    <p class="text-white text-sm">Δευ-Παρ, 9πμ-6μμ</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Social Links at bottom -->
            <div class="mt-10 pt-6 border-t border-purple-500/30">
              <p class="text-xs font-medium text-purple-300 uppercase tracking-wider mb-4">Ακολουθήστε μας</p>
              <div class="flex items-center gap-3">
                <a href="https://x.com/210designs" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-lg bg-white/10 border border-white/20 flex items-center justify-center text-purple-200 hover:text-white hover:bg-gradient-to-br hover:from-primary-600 hover:to-violet-500 hover:border-transparent transition-all duration-300" aria-label="Twitter">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                  </svg>
                </a>
                <a href="https://instagram.com/210designs" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-lg bg-white/10 border border-white/20 flex items-center justify-center text-purple-200 hover:text-white hover:bg-gradient-to-br hover:from-primary-600 hover:to-violet-500 hover:border-transparent transition-all duration-300" aria-label="Instagram">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Column — Contact Form (wider) -->
        <div class="lg:col-span-3 gs-reveal">
          <div class="bg-white rounded-2xl shadow-xl shadow-purple-500/5 p-8 md:p-10 border border-neutral-100">
            <form id="contact-form" class="space-y-5" novalidate>
              <!-- Name & Email row -->
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="name" class="block text-sm font-medium text-neutral-700 mb-1.5">Όνομα</label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    placeholder="Το πλήρες όνομά σας"
                    class="w-full rounded-xl border border-neutral-200 px-4 py-3 text-neutral-800 placeholder:text-neutral-400 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none transition"
                  />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-neutral-700 mb-1.5">Email</label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    placeholder="you@company.com"
                    class="w-full rounded-xl border border-neutral-200 px-4 py-3 text-neutral-800 placeholder:text-neutral-400 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none transition"
                  />
                </div>
              </div>

              <!-- Project Type & Budget row -->
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="project-type" class="block text-sm font-medium text-neutral-700 mb-1.5">Τύπος Project</label>
                  <select
                    id="project-type"
                    name="project-type"
                    required
                    class="w-full rounded-xl border border-neutral-200 px-4 py-3 text-neutral-800 bg-white focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none transition"
                  >
                    <option value="" disabled selected>Επιλέξτε τύπο project</option>
                    <option value="website-design">Κατασκευή Ιστοσελίδας</option>
                    <option value="seo-optimization">Βελτιστοποίηση SEO</option>
                    <option value="other">Άλλο</option>
                  </select>
                </div>
                <div>
                  <label for="budget" class="block text-sm font-medium text-neutral-700 mb-1.5">Εύρος Προϋπολογισμού</label>
                  <select
                    id="budget"
                    name="budget"
                    required
                    class="w-full rounded-xl border border-neutral-200 px-4 py-3 text-neutral-800 bg-white focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none transition"
                  >
                    <option value="" disabled selected>Επιλέξτε τον προϋπολογισμό σας</option>
                  </select>
                </div>
              </div>

              <!-- Message -->
              <div>
                <label for="message" class="block text-sm font-medium text-neutral-700 mb-1.5">Μήνυμα</label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  placeholder="Πείτε μας για το project σας..."
                  class="w-full rounded-xl border border-neutral-200 px-4 py-3 text-neutral-800 placeholder:text-neutral-400 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none transition resize-y"
                ></textarea>
              </div>

              <!-- Submit Button -->
              <button
                type="submit"
                class="w-full inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white rounded-xl transition-all duration-300 shadow-lg shadow-purple-500/25 hover:shadow-purple-500/40 hover:scale-[1.02] bg-gradient-to-r from-purple-600 to-violet-600"
              >
                Αποστολή Μηνύματος
                <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
              </button>

              <!-- Success Message (hidden by default) -->
              <div id="form-success" class="hidden rounded-xl bg-green-50 border border-green-200 p-4 text-center">
                <p class="text-green-700 font-medium">Ευχαριστούμε! Το μήνυμα σας στάλθηκε. Θα επικοινωνήσουμε σύντομα.</p>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTASection heading="Προτιμάτε να Κλείσετε Ραντεβού;" buttonText="Κλείστε μια Συνάντηση" />

  <script>
    // Dynamic budget options based on project type
    const projectTypeSelect = document.getElementById('project-type') as HTMLSelectElement;
    const budgetSelect = document.getElementById('budget') as HTMLSelectElement;

    const budgetOptions: Record<string, { value: string; label: string }[]> = {
      'website-design': [
        { value: 'professional', label: 'Professional - €270' },
        { value: 'premium', label: 'Premium - €550' },
        { value: 'custom', label: 'Custom - Κατόπιν συνεννόησης' },
      ],
      'seo-optimization': [
        { value: 'seo-boost', label: 'SEO Boost - €250/μήνα' },
        { value: 'seo-dominate', label: 'SEO Dominate - €400/μήνα' },
      ],
      'other': [
        { value: 'custom', label: 'Κατόπιν συνεννόησης' },
      ],
    };

    if (projectTypeSelect && budgetSelect) {
      projectTypeSelect.addEventListener('change', () => {
        const type = projectTypeSelect.value;
        const options = budgetOptions[type] || [];

        budgetSelect.innerHTML = '<option value="" disabled selected>Επιλέξτε τον προϋπολογισμό σας</option>';
        options.forEach((opt) => {
          const option = document.createElement('option');
          option.value = opt.value;
          option.textContent = opt.label;
          budgetSelect.appendChild(option);
        });
      });
    }

    const form = document.getElementById('contact-form') as HTMLFormElement;
    const successMsg = document.getElementById('form-success') as HTMLDivElement;

    form?.addEventListener('submit', (e) => {
      e.preventDefault();

      const name = (form.querySelector('#name') as HTMLInputElement).value.trim();
      const email = (form.querySelector('#email') as HTMLInputElement).value.trim();
      const projectType = (form.querySelector('#project-type') as HTMLSelectElement).value;
      const budget = (form.querySelector('#budget') as HTMLSelectElement).value;
      const message = (form.querySelector('#message') as HTMLTextAreaElement).value.trim();

      if (!name || !email || !projectType || !budget || !message) {
        return;
      }

      // Simple email check
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        return;
      }

      // Simulate successful submission
      form.reset();
      successMsg?.classList.remove('hidden');

      setTimeout(() => {
        successMsg?.classList.add('hidden');
      }, 5000);
    });
  </script>
</BaseLayout>
