---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ProcessTimeline from '../components/ProcessTimeline.astro';
import CTASection from '../components/CTASection.astro';

const services = [
  {
    number: "01",
    title: "Web Design",
    description: "Δημιουργούμε εντυπωσιακούς, ανθρωποκεντρικούς σχεδιασμούς που μαγεύουν το κοινό σας και αυξάνουν την αλληλεπίδραση.",
    image: "https://images.unsplash.com/photo-1561070791-2526d30994b5?w=800&q=80",
    features: [
      "Προσαρμοσμένος Σχεδιασμός UI/UX",
      "Responsive Διατάξεις",
      "Διαδραστικά Prototypes",
      "Δημιουργία Design System",
      "Έρευνα Χρηστών & Testing",
    ],
  },
  {
    number: "02",
    title: "Web Development",
    description: "Χτίζουμε ισχυρές, κλιμακούμενες ιστοσελίδες και web εφαρμογές χρησιμοποιώντας τεχνολογίες αιχμής.",
    image: "https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=800&q=80",
    features: [
      "Frontend Ανάπτυξη",
      "Backend & API Ανάπτυξη",
      "Ενσωμάτωση CMS",
      "Λύσεις E-commerce",
      "Βελτιστοποίηση Απόδοσης",
    ],
  },
  {
    number: "03",
    title: "Δημιουργικό & Branding",
    description: "Δημιουργούμε συναρπαστικές ταυτότητες brand που αφηγούνται την ιστορία σας και συνδέονται με το κοινό σας.",
    image: "https://images.unsplash.com/photo-1558655146-9f40138edfeb?w=800&q=80",
    features: [
      "Στρατηγική Brand",
      "Λογότυπο & Οπτική Ταυτότητα",
      "Οδηγίες Brand",
      "Υλικό Marketing",
      "Motion Graphics",
    ],
  },
];
---

<BaseLayout title="Υπηρεσίες | 210Designs" description="Από την ιδέα μέχρι την κυκλοφορία, δίνουμε ζωή στο ψηφιακό σας όραμα. Εξερευνήστε τις υπηρεσίες web design, ανάπτυξης και branding.">
  <PageHero
    title="Οι Υπηρεσίες μας"
    subtitle="Από την ιδέα μέχρι την κυκλοφορία, δίνουμε ζωή στο ψηφιακό σας όραμα"
    gradient={true}
    breadcrumbs={[
      { label: "Αρχική", href: "/" },
      { label: "Υπηρεσίες", href: "/services" },
    ]}
  />

  <!-- Service Sections -->
  {services.map((service, index) => {
    const isEven = index % 2 === 0;
    const isDark = index % 2 !== 0;
    return (
      <section class:list={[
        "py-20 md:py-28 relative overflow-hidden",
        isDark ? "bg-gradient-to-br from-purple-200 via-violet-200 to-purple-300" : ""
      ]}>
        {/* Decorative blobs */}
        <div class:list={["blob", isDark ? "blob-purple" : "blob-blue", "-top-40", isEven ? "-right-40" : "-left-40", "opacity-15"]}></div>

        <div class="relative max-w-6xl mx-auto px-6 lg:px-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-center">
            {/* Text side */}
            <div class={`${isEven ? 'md:order-1' : 'md:order-2'}`}>
              <div class={isEven ? 'gs-reveal-left' : 'gs-reveal-right'}>
                <span class="block text-8xl font-display font-bold leading-none select-none gradient-text">
                  {service.number}
                </span>
                <h2 class:list={[
                  "mt-4 text-3xl font-display font-bold",
                  isDark ? "text-neutral-900" : "text-neutral-900"
                ]}>
                  {service.title}
                </h2>
                <p class:list={[
                  "mt-4 leading-relaxed",
                  isDark ? "text-neutral-700" : "text-neutral-600"
                ]}>
                  {service.description}
                </p>
                <ul class="mt-6 space-y-3">
                  {service.features.map((feature) => (
                    <li class:list={[
                      "flex items-center gap-3",
                      isDark ? "text-neutral-800" : "text-neutral-700"
                    ]}>
                      {/* Gradient circle checkmark */}
                      <span class="flex-shrink-0 w-6 h-6 rounded-full bg-gradient-to-br from-primary-500 to-violet-500 flex items-center justify-center">
                        <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                      </span>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            {/* Image side */}
            <div class={`${isEven ? 'md:order-2' : 'md:order-1'}`}>
              <div class={isEven ? 'gs-reveal-right' : 'gs-reveal-left'}>
                <div class="image-hover rounded-2xl">
                  <img
                    src={service.image}
                    alt={service.title}
                    class="w-full h-auto rounded-2xl object-cover aspect-video"
                    loading="lazy"
                  />
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    );
  })}

  <!-- Our Process -->
  <section class="bg-gradient-to-br from-purple-200 via-violet-200 to-purple-300 py-16 md:py-24 relative overflow-hidden">
    <div class="blob blob-purple -top-40 -right-40 opacity-15"></div>
    <div class="blob blob-blue -bottom-40 -left-40 opacity-10"></div>

    <div class="relative max-w-6xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-12 md:mb-16">
        <h2 class="gs-reveal font-display text-3xl md:text-4xl font-bold">
          Πώς <span class="gradient-text">Δουλεύουμε</span>
        </h2>
      </div>
      <ProcessTimeline />
    </div>
  </section>

  <!-- CTA -->
  <CTASection heading="Έχετε ένα Project στο Μυαλό σας;" />
</BaseLayout>
