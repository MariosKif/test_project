---
import BaseLayout from '../layouts/BaseLayout.astro';
import PricingCard from '../components/PricingCard.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTASection from '../components/CTASection.astro';

const faqItems = [
  {
    question: "Πόσο διαρκεί ένα τυπικό project;",
    answer: "Ο χρόνος κάθε project ποικίλλει ανάλογα με το εύρος και την πολυπλοκότητα. Μια τυπική ιστοσελίδα χρειάζεται συνήθως 4-6 εβδομάδες από την έναρξη μέχρι την κυκλοφορία. Πιο σύνθετα projects όπως e-commerce ή web εφαρμογές μπορεί να χρειαστούν 8-12 εβδομάδες. Θα σας δώσουμε λεπτομερές χρονοδιάγραμμα κατά την αρχική συνάντηση.",
  },
  {
    question: "Τι περιλαμβάνει η σχεδιαστική διαδικασία;",
    answer: "Η σχεδιαστική μας διαδικασία περιλαμβάνει εργαστήρια ανακάλυψης, wireframing, οπτικά σχέδια, διαδραστικά prototypes και επαναληπτικές αναθεωρήσεις. Πιστεύουμε στον συνεργατικό σχεδιασμό — θα συμμετέχετε σε κάθε στάδιο για να διασφαλίσετε ότι το τελικό αποτέλεσμα ευθυγραμμίζεται με το όραμά σας.",
  },
  {
    question: "Προσφέρετε συνεχή συντήρηση;",
    answer: "Ναι! Προσφέρουμε μηνιαία πακέτα συντήρησης από 500€/μήνα που περιλαμβάνουν ενημερώσεις ασφαλείας, αλλαγές περιεχομένου, παρακολούθηση απόδοσης και υποστήριξη προτεραιότητας. Θέλουμε να είμαστε ο μακροχρόνιος ψηφιακός σας συνεργάτης.",
  },
  {
    question: "Μπορώ να αναβαθμίσω το πακέτο μου αργότερα;",
    answer: "Φυσικά. Τα πακέτα μας είναι αφετηρίες. Μπορούμε πάντα να προσθέσουμε δυνατότητες, σελίδες ή λειτουργικότητα καθώς η επιχείρησή σας αναπτύσσεται. Πολλοί πελάτες μας ξεκινούν με το πακέτο Starter και κλιμακώνουν με τον καιρό.",
  },
  {
    question: "Τι τεχνολογίες χρησιμοποιείτε;",
    answer: "Δουλεύουμε με σύγχρονες, κορυφαίες τεχνολογίες όπως React, Next.js, Astro, Tailwind CSS και άλλες. Επιλέγουμε το καλύτερο tech stack για κάθε project βάσει των συγκεκριμένων αναγκών σας, των απαιτήσεων απόδοσης και της μακροχρόνιας συντηρησιμότητας.",
  },
];
---

<BaseLayout title="Τιμές | 210Designs" description="Απλές, διαφανείς τιμές. Επιλέξτε το πακέτο που σας ταιριάζει.">
  <!-- Pricing Cards -->
  <section class="pt-16 pb-20 md:pt-24 md:pb-28">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <h2 class="gs-reveal font-display text-3xl md:text-4xl font-bold text-neutral-900 text-center mb-16">
        Κατασκευή Ιστοσελίδων <span class="gradient-text">Πακέτα</span>
      </h2>

      <div class="gs-stagger grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="gs-reveal">
          <PricingCard
            name="Landing Page"
            price="€300"
            hosting="+ Hosting 120€/έτος +ΦΠΑ"
            features={[
              "Έως 5 σελίδες (π.χ. Αρχική, Υπηρεσίες, Σχετικά, Portfolio, Επικοινωνία)",
              "Responsive σε desktop, tablet & κινητό",
              "Φόρμα επικοινωνίας",
              "Ταχύτατη φόρτωση & καθαρό UX",
              "3 Κύκλοι Διορθώσεων",
            ]}
          />
        </div>

        <div class="gs-reveal">
          <PricingCard
            name="Επαγγελματική Ιστοσελίδα"
            price="€550"
            hosting="+ Hosting 120€/έτος +ΦΠΑ"
            highlighted={true}
            features={[
              "Έως 8 σελίδες με προσαρμοσμένο σχεδιασμό",
              "Responsive σε desktop, tablet & κινητό",
              "Προηγμένα animations & εφέ",
              "Φόρμα επικοινωνίας",
              "Ταχύτατη φόρτωση & καθαρό UX",
              "Βελτιστοποίηση SEO",
              "Εγκατάσταση Blog",
              "Βελτιστοποίηση Απόδοσης",
              "3 Κύκλοι Διορθώσεων",
            ]}
          />
        </div>

        <div class="gs-reveal">
          <PricingCard
            name="Custom"
            price="Custom"
            description="Εξατομικευμένη τιμή βάσει των αναγκών και της πολυπλοκότητας του project σας."
            features={[]}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- SEO Package -->
  <section class="py-20 md:py-28 border-t border-neutral-100">
    <div class="max-w-5xl mx-auto px-6 lg:px-8">
      <h2 class="gs-reveal font-display text-3xl md:text-4xl font-bold text-neutral-900 text-center mb-16">
        Πακέτα <span class="gradient-text">SEO</span>
      </h2>

      <div class="gs-stagger grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="gs-reveal">
          <PricingCard
            name="SEO Essential"
            price="€250"
            period="/mo"
            description="Χτίστε μια ισχυρή βάση SEO και αρχίστε να ανεβαίνετε στις κατατάξεις."
            buttonText="Ξεκινήστε"
            features={[
              "Τεχνικό SEO Audit & Διορθώσεις",
              "Έρευνα Λέξεων-Κλειδιών & Στρατηγική",
              "On-Page Βελτιστοποίηση",
              "Μηνιαίες Αναφορές Απόδοσης",
              "Συστάσεις Περιεχομένου",
              "Ρύθμιση Google Search Console",
              "Ανάλυση Ανταγωνισμού",
              "Στρατηγική Link Building",
            ]}
          />
        </div>

        <div class="gs-reveal">
          <PricingCard
            name="SEO Pro"
            price="€400"
            period="/mo"
            description="Προηγμένο SEO για επιχειρήσεις που θέλουν να κυριαρχήσουν στα αποτελέσματα αναζήτησης."
            highlighted={true}
            buttonText="Ξεκινήστε"
            features={[
              "Όλα όσα περιλαμβάνει το SEO Essential",
              "Προηγμένη Τεχνική Βελτιστοποίηση",
              "Δημιουργία & Δημοσίευση Περιεχομένου",
              "Τοπικό SEO & Google Business",
              "Backlink Outreach & Απόκτηση",
              "Εβδομαδιαίες Αναφορές Απόδοσης",
              "Βελτιστοποίηση Ποσοστού Μετατροπής",
              "Αποκλειστικός SEO Στρατηγικός",
            ]}
          />
        </div>
      </div>
      <p class="gs-reveal text-center text-sm text-neutral-400 mt-8">Μηνιαία χρέωση. Χωρίς μακροχρόνια συμβόλαια.</p>
    </div>
  </section>

  <!-- FAQ Section -->
  <section id="faq" class="py-20 md:py-28 border-t border-neutral-100">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-12 md:mb-16">
        <h2 class="gs-reveal font-display text-3xl md:text-4xl font-bold text-neutral-900">
          Συχνές <span class="gradient-text">Ερωτήσεις</span>
        </h2>
      </div>
      <div class="gs-reveal">
        <FAQAccordion items={faqItems} />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTASection heading="Χρειάζεστε Προσαρμοσμένη Λύση;" buttonText="Επικοινωνήστε" />
</BaseLayout>
