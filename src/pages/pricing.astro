---
import BaseLayout from '../layouts/BaseLayout.astro';
import PricingCard from '../components/PricingCard.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTASection from '../components/CTASection.astro';

const faqItems = [
  {
    question: "Θα είναι η ιστοσελίδα μου φιλική προς κινητά;",
    answer: "Απολύτως. Όλες οι ιστοσελίδες που κατασκευάζουμε είναι πλήρως responsive και προσαρμόζονται αυτόματα σε κινητά, tablets και desktop. Δοκιμάζουμε σε πραγματικές συσκευές πριν την παράδοση για να εξασφαλίσουμε άψογη εμπειρία παντού.",
  },
  {
    question: "Τι χρειάζεται να μου δώσετε εσείς για να ξεκινήσουμε;",
    answer: "Χρειαζόμαστε το λογότυπό σας, τα κείμενα που θέλετε στην ιστοσελίδα, φωτογραφίες (αν υπάρχουν) και μια γενική ιδέα για το στυλ που σας αρέσει. Αν δεν έχετε κάτι από αυτά, μπορούμε να σας βοηθήσουμε να τα δημιουργήσετε.",
  },
  {
    question: "Μπορώ να κάνω αλλαγές μόνος μου μετά την παράδοση;",
    answer: "Ναι, αν η ιστοσελίδα σας περιλαμβάνει CMS (σύστημα διαχείρισης περιεχομένου), μπορείτε να αλλάξετε κείμενα, εικόνες και να προσθέσετε νέο περιεχόμενο χωρίς τεχνικές γνώσεις. Σας παρέχουμε και σύντομη εκπαίδευση μετά την παράδοση.",
  },
  {
    question: "Τι γίνεται αν χρειαστώ βοήθεια μετά την ολοκλήρωση;",
    answer: "Προσφέρουμε τεχνική υποστήριξη και μετά την παράδοση. Για μικρές αλλαγές ή τεχνικά ζητήματα, μπορείτε να μας στείλετε email και θα ανταποκριθούμε εντός 24 ωρών. Για πιο εκτεταμένες ανάγκες, μπορούμε να συζητήσουμε ένα πακέτο συντήρησης.",
  },
  {
    question: "Πώς γίνεται η πληρωμή;",
    answer: "Η πληρωμή γίνεται σε δύο δόσεις: 50% κατά την έναρξη του project και το υπόλοιπο 50% κατά την παράδοση. Δεχόμαστε τραπεζικό έμβασμα, κάρτα και Revolut. Για τα πακέτα SEO η χρέωση γίνεται μηνιαία.",
  },
];
---

<BaseLayout title="Τιμές | 210Designs" description="Απλές, διαφανείς τιμές. Επιλέξτε το πακέτο που σας ταιριάζει.">
  <!-- Pricing Cards -->
  <section class="pt-16 pb-20 md:pt-24 md:pb-28">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <h2 class="gs-reveal font-display text-3xl md:text-4xl font-bold text-neutral-900 text-center mb-16">
        Κατασκευή Ιστοσελίδων <span class="gradient-text">Πακέτα</span>
      </h2>

      <div class="gs-stagger grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="gs-reveal">
          <PricingCard
            name="Professional"
            price="€270"
            hosting="+ Hosting 90€/έτος +ΦΠΑ"
            features={[
              "Μέχρι 5 σελίδες",
              "Responsive design για όλες τις συσκευές",
              "Φόρμα επικοινωνίας",
              "Γρήγορο και εύχρηστο site",
              "3 διορθώσεις included",
            ]}
          />
        </div>

        <div class="gs-reveal">
          <PricingCard
            name="Premium"
            price="€550"
            hosting="+ Hosting 90€/έτος +ΦΠΑ"
            highlighted={true}
            features={[
              "Μέχρι 10 σελίδες",
              "Responsive design για όλες τις συσκευές",
              "Φόρμα επικοινωνίας",
              "Γρήγορο και εύχρηστο site",
              "Προηγμένα animations & εφέ",
              "Βελτιστοποίηση SEO",
              "Εγκατάσταση Blog",
              "Βελτιστοποίηση απόδοσης",
              "5 διορθώσεις included",
            ]}
          />
        </div>

        <div class="gs-reveal">
          <PricingCard
            name="Custom"
            price="Custom"
            description="Εξατομικευμένη τιμή βάσει των αναγκών και της πολυπλοκότητας του project σας."
            features={[]}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- SEO Package -->
  <section class="py-20 md:py-28 border-t border-neutral-100">
    <div class="max-w-5xl mx-auto px-6 lg:px-8">
      <h2 class="gs-reveal font-display text-3xl md:text-4xl font-bold text-neutral-900 text-center mb-16">
        Πακέτα <span class="gradient-text">SEO</span>
      </h2>

      <div class="gs-stagger grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="gs-reveal">
          <PricingCard
            name="SEO Boost"
            price="€250"
            period="/mo"
            description="Χτίστε μια ισχυρή βάση SEO και αρχίστε να ανεβαίνετε στις κατατάξεις."
            buttonText="Ξεκινήστε"
            features={[
              "Τεχνικό SEO Audit & Διορθώσεις",
              "Έρευνα Λέξεων-Κλειδιών & Στρατηγική",
              "On-Page Βελτιστοποίηση",
              "Μηνιαίες Αναφορές Απόδοσης",
              "Συστάσεις Περιεχομένου",
              "Ρύθμιση Google Search Console",
              "Ανάλυση Ανταγωνισμού",
              "Στρατηγική Link Building",
            ]}
          />
        </div>

        <div class="gs-reveal">
          <PricingCard
            name="SEO Dominate"
            price="€400"
            period="/mo"
            description="Προηγμένο SEO για επιχειρήσεις που θέλουν να κυριαρχήσουν στα αποτελέσματα αναζήτησης."
            highlighted={true}
            buttonText="Ξεκινήστε"
            features={[
              "Όλα όσα περιλαμβάνει το SEO Boost",
              "Προηγμένη Τεχνική Βελτιστοποίηση",
              "Δημιουργία & Δημοσίευση Περιεχομένου",
              "Τοπικό SEO & Google Business",
              "Backlink Outreach & Απόκτηση",
              "Εβδομαδιαίες Αναφορές Απόδοσης",
              "Βελτιστοποίηση Ποσοστού Μετατροπής",
              "Αποκλειστικός SEO Στρατηγικός",
            ]}
          />
        </div>
      </div>
      <p class="gs-reveal text-center text-sm text-neutral-400 mt-8">Μηνιαία χρέωση. Χωρίς μακροχρόνια συμβόλαια.</p>
    </div>
  </section>

  <!-- FAQ Section -->
  <section id="faq" class="py-20 md:py-28 border-t border-neutral-100">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-12 md:mb-16">
        <h2 class="gs-reveal font-display text-3xl md:text-4xl font-bold text-neutral-900">
          Συχνές <span class="gradient-text">Ερωτήσεις</span>
        </h2>
      </div>
      <div class="gs-reveal">
        <FAQAccordion items={faqItems} />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTASection heading="Χρειάζεστε Προσαρμοσμένη Λύση;" buttonText="Επικοινωνήστε" />
</BaseLayout>
