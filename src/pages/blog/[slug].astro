---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import CTASection from '../../components/CTASection.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// Format date
const formattedDate = post.data.date.toLocaleDateString('el-GR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Estimate reading time (~200 words per minute)
const body = post.body ?? '';
const wordCount = body.split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// Author initials
const initials = post.data.author
  .split(' ')
  .map((n: string) => n[0])
  .join('')
  .toUpperCase();

// Table of contents from h2 headings
const toc = headings.filter((h) => h.depth === 2);

// Related posts (exclude current, limit to 3)
const allPosts = (await getCollection('blog'))
  .filter((p) => p.id !== post.id)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout
  title={`${post.data.title} | 210Designs Blog`}
  description={post.data.description}
>
  <!-- Reading Progress Bar -->
  <div id="progress-bar" class="fixed top-0 left-0 h-1 bg-gradient-to-r from-primary-500 to-violet-500 z-[100] transition-all duration-100" style="width: 0%"></div>

  <!-- Article Header -->
  <section class="pt-16 md:pt-24 pb-8">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <!-- Meta row: category + reading time -->
      <div class="gs-reveal flex items-center gap-3 mb-6">
        <span class="inline-block text-xs font-semibold uppercase tracking-wider text-white rounded-full px-4 py-1.5 bg-gradient-to-r from-primary-600 to-violet-500">
          {post.data.category}
        </span>
        <span class="text-sm text-neutral-400">{readingTime} λεπτά ανάγνωσης</span>
      </div>

      <!-- Title -->
      <h1 class="gs-reveal font-display text-3xl md:text-4xl lg:text-5xl font-bold text-neutral-900 leading-tight mb-6">
        {post.data.title}
      </h1>

      <!-- Description -->
      <p class="gs-reveal text-lg text-neutral-500 leading-relaxed mb-8 max-w-3xl">
        {post.data.description}
      </p>

      <!-- Author & Date -->
      <div class="gs-reveal flex items-center gap-4 pb-8 border-b border-neutral-200">
        <div class="w-11 h-11 rounded-full bg-gradient-to-br from-primary-500 to-violet-500 flex items-center justify-center flex-shrink-0">
          <span class="text-xs font-bold text-white">{initials}</span>
        </div>
        <div>
          <p class="font-medium text-neutral-900 text-sm">{post.data.author}</p>
          <time datetime={post.data.date.toISOString()} class="text-sm text-neutral-400">{formattedDate}</time>
        </div>
      </div>

      <!-- Featured Image -->
      {post.data.image && (
        <div class="gs-reveal mt-8 rounded-2xl overflow-hidden">
          <img
            src={post.data.image}
            alt={post.data.title}
            class="w-full h-auto aspect-video object-cover"
            loading="eager"
          />
        </div>
      )}
    </div>
  </section>

  <!-- Article Body with TOC sidebar -->
  <section class="py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <!-- Table of Contents - inline -->
        {toc.length > 0 && (
          <div class="mb-12 rounded-2xl border border-neutral-200 p-6">
            <p class="text-xs font-semibold uppercase tracking-wider text-neutral-400 mb-4">Περιεχόμενα</p>
            <nav class="space-y-2">
              {toc.map((heading) => (
                <a
                  href={`#${heading.slug}`}
                  class="toc-link block text-sm text-neutral-400 hover:text-primary-600 transition-colors duration-200 py-1 border-l-2 border-transparent hover:border-primary-500 pl-3"
                >
                  {heading.text}
                </a>
              ))}
            </nav>
          </div>
        )}

        <!-- Article Content -->
        <article class="
          [&>p]:text-lg [&>p]:leading-relaxed [&>p]:text-neutral-700 [&>p]:mb-6
          [&>h2]:font-display [&>h2]:text-2xl [&>h2]:md:text-3xl [&>h2]:font-bold [&>h2]:text-neutral-900 [&>h2]:mb-4 [&>h2]:mt-12 [&>h2]:pt-4 [&>h2]:scroll-mt-24
          [&>h3]:font-display [&>h3]:text-xl [&>h3]:font-semibold [&>h3]:text-neutral-900 [&>h3]:mb-4 [&>h3]:mt-10 [&>h3]:scroll-mt-24
          [&>h4]:font-display [&>h4]:text-lg [&>h4]:font-semibold [&>h4]:text-neutral-900 [&>h4]:mb-3 [&>h4]:mt-8
          [&>a]:text-primary-600 [&>a]:underline [&>a]:underline-offset-2
          [&>ul]:list-disc [&>ul]:pl-6 [&>ul]:mb-6 [&>ul]:text-neutral-700 [&>ul]:space-y-2
          [&>ol]:list-decimal [&>ol]:pl-6 [&>ol]:mb-6 [&>ol]:text-neutral-700 [&>ol]:space-y-2
          [&>blockquote]:border-l-4 [&>blockquote]:border-primary-400 [&>blockquote]:pl-6 [&>blockquote]:italic [&>blockquote]:text-neutral-600 [&>blockquote]:my-8 [&>blockquote]:bg-primary-50 [&>blockquote]:py-4 [&>blockquote]:pr-6 [&>blockquote]:rounded-r-xl
          [&>img]:rounded-xl [&>img]:my-8
          [&>hr]:my-10 [&>hr]:border-neutral-200
        ">
          <Content />
        </article>
      </div>
    </div>
  </section>

  <!-- Share & Tags -->
  <section class="pb-12">
    <div class="max-w-3xl mx-auto px-6 lg:px-8 ">
      <!-- Tags -->
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-8">
          {post.data.tags.map((tag: string) => (
            <span class="text-xs font-medium text-neutral-500 bg-neutral-100 rounded-full px-3 py-1.5">
              {tag}
            </span>
          ))}
        </div>
      )}

      <!-- Share buttons -->
      <div class="flex items-center gap-4 pt-6 border-t border-neutral-200">
        <span class="text-sm font-medium text-neutral-500">Κοινοποίηση:</span>
        <a
          href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(`https://210designs.com/blog/${post.id}`)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="w-9 h-9 rounded-lg bg-neutral-100 hover:bg-primary-100 flex items-center justify-center text-neutral-500 hover:text-primary-600 transition-all duration-200"
          aria-label="Share on X"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
        </a>
        <button
          id="copy-link"
          class="w-9 h-9 rounded-lg bg-neutral-100 hover:bg-primary-100 flex items-center justify-center text-neutral-500 hover:text-primary-600 transition-all duration-200"
          aria-label="Copy link"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
          </svg>
        </button>
      </div>
    </div>
  </section>

  <!-- Author Bio -->
  <section class="pb-16">
    <div class="max-w-3xl mx-auto px-6 lg:px-8 ">
      <div class="gs-reveal rounded-2xl border border-neutral-200 p-6 md:p-8">
        <div class="flex items-start gap-5">
          <div class="w-14 h-14 rounded-full bg-gradient-to-br from-primary-500 to-violet-500 flex items-center justify-center flex-shrink-0">
            <span class="text-sm font-bold text-white">{initials}</span>
          </div>
          <div>
            <p class="font-semibold text-neutral-900 text-lg">{post.data.author}</p>
            <p class="text-sm text-neutral-500 mt-1 leading-relaxed">
              Content strategist στην 210Designs. Γράφει για web design, ανάπτυξη και ψηφιακές στρατηγικές που βοηθούν επιχειρήσεις να αναπτυχθούν online.
            </p>
            <a href="/contact" class="inline-flex items-center mt-3 text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors">
              Επικοινωνήστε μαζί μας &rarr;
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Posts -->
  {allPosts.length > 0 && (
    <section class="py-20 md:py-24 border-t border-neutral-100">
      <div class="max-w-7xl mx-auto px-6">
        <h2 class="gs-reveal font-display text-2xl md:text-3xl font-bold text-center mb-12">
          Περισσότερα <span class="gradient-text">Άρθρα</span>
        </h2>
        <div class="gs-stagger grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {allPosts.map((related) => (
            <BlogCard
              image={related.data.image}
              title={related.data.title}
              excerpt={related.data.description}
              date={related.data.date.toLocaleDateString('el-GR', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
              category={related.data.category}
              slug={related.id}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <CTASection heading="Θέλετε να Μένετε Ενημερωμένοι;" buttonText="Επικοινωνία" />

  <script>
    // Reading progress bar
    const progressBar = document.getElementById('progress-bar');
    if (progressBar) {
      window.addEventListener('scroll', () => {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = Math.min((scrollTop / docHeight) * 100, 100);
        progressBar.style.width = `${progress}%`;
      });
    }

    // Active TOC highlighting
    const tocLinks = document.querySelectorAll('.toc-link');
    const headings = document.querySelectorAll('article h2[id]');

    if (tocLinks.length > 0 && headings.length > 0) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              tocLinks.forEach((link) => {
                link.classList.remove('!text-primary-600', '!border-primary-500', 'font-medium');
              });
              const activeLink = document.querySelector(`.toc-link[href="#${entry.target.id}"]`);
              if (activeLink) {
                activeLink.classList.add('!text-primary-600', '!border-primary-500', 'font-medium');
              }
            }
          });
        },
        { rootMargin: '-80px 0px -60% 0px' }
      );

      headings.forEach((heading) => observer.observe(heading));
    }

    // Copy link button
    const copyBtn = document.getElementById('copy-link');
    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        navigator.clipboard.writeText(window.location.href);
        copyBtn.innerHTML = '<svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>';
        setTimeout(() => {
          copyBtn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>';
        }, 2000);
      });
    }
  </script>
</BaseLayout>
