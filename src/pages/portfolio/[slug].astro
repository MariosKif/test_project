---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('portfolio');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const categoryLabels: Record<string, string> = {
  'web-design': 'Web Design',
  'development': 'Ανάπτυξη',
  'creative': 'Δημιουργικό',
};

// Hero background images based on category
const categoryHeroImages: Record<string, string> = {
  'web-design': 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=1200&q=80',
  'development': 'https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=1200&q=80',
  'creative': 'https://images.unsplash.com/photo-1558655146-9f40138edfeb?w=1200&q=80',
};
const heroImage = categoryHeroImages[project.data.category] || categoryHeroImages['web-design'];

const galleryImages = [
  'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=600&q=80',
  'https://images.unsplash.com/photo-1499951360447-b19be8fe80f5?w=600&q=80',
  'https://images.unsplash.com/photo-1486312338219-ce68d2c6f44d?w=600&q=80',
];

// Next / Previous navigation
const allProjects = await getCollection('portfolio');
const currentIndex = allProjects.findIndex((p) => p.id === project.id);
const prevProject = currentIndex > 0 ? allProjects[currentIndex - 1] : null;
const nextProject = currentIndex < allProjects.length - 1 ? allProjects[currentIndex + 1] : null;
---

<BaseLayout title={`${project.data.title} | 210Designs`} description={project.data.description}>
  <!-- Hero Section with background image -->
  <section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden">
    <img
      src={heroImage}
      alt={project.data.title}
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="hero-overlay absolute inset-0"></div>

    <div class="relative text-center px-6 py-20">
      <!-- Breadcrumbs -->
      <nav class="gs-reveal mb-6" aria-label="Breadcrumb">
        <ol class="flex items-center justify-center gap-2 text-sm text-neutral-300">
          <li>
            <a href="/" class="hover:text-primary-400 transition-colors duration-200">Αρχική</a>
          </li>
          <li class="select-none" aria-hidden="true">/</li>
          <li>
            <a href="/portfolio" class="hover:text-primary-400 transition-colors duration-200">Portfolio</a>
          </li>
          <li class="select-none" aria-hidden="true">/</li>
          <li>
            <span class="text-white">{project.data.title}</span>
          </li>
        </ol>
      </nav>

      <h1 class="gs-reveal font-display text-4xl md:text-6xl font-bold text-white leading-tight max-w-4xl mx-auto">
        {project.data.title}
      </h1>
      <div class="gs-reveal mt-5">
        <span class="inline-block px-5 py-2 text-xs uppercase tracking-wider font-medium text-white bg-gradient-to-r from-primary-600 to-violet-500 rounded-full">
          {categoryLabels[project.data.category] || project.data.category}
        </span>
      </div>
    </div>
  </section>

  <!-- Project Overview Info Bar -->
  <section class="bg-gradient-to-br from-purple-200 via-violet-200 to-purple-300 py-14">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <div class="gs-reveal glass-dark p-8 grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <span class="block text-xs uppercase tracking-wider text-neutral-500 mb-1">Πελάτης</span>
          <span class="text-white font-medium">{project.data.client}</span>
        </div>
        <div>
          <span class="block text-xs uppercase tracking-wider text-neutral-500 mb-1">Έτος</span>
          <span class="text-white font-medium">{project.data.year}</span>
        </div>
        <div>
          <span class="block text-xs uppercase tracking-wider text-neutral-500 mb-1">Κατηγορία</span>
          <span class="text-white font-medium">{categoryLabels[project.data.category] || project.data.category}</span>
        </div>
        <div>
          <span class="block text-xs uppercase tracking-wider text-neutral-500 mb-1">Tech Stack</span>
          <span class="text-white font-medium">{project.data.techStack.join(', ')}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- The Challenge -->
  <section class="py-16 md:py-20">
    <div class="gs-reveal max-w-3xl mx-auto px-6 lg:px-8">
      <span class="block text-sm uppercase tracking-wider font-medium gradient-text mb-4">Η Πρόκληση</span>
      <p class="text-lg text-neutral-700 leading-relaxed">{project.data.challenge}</p>
    </div>
  </section>

  <!-- Our Solution -->
  <section class="bg-gradient-to-br from-purple-200 via-violet-200 to-purple-300 py-16 md:py-20 relative overflow-hidden">
    <div class="blob blob-purple -top-40 -right-40 opacity-15"></div>
    <div class="relative gs-reveal max-w-3xl mx-auto px-6 lg:px-8">
      <span class="block text-sm uppercase tracking-wider font-medium gradient-text mb-4">Η Λύση μας</span>
      <p class="text-lg text-neutral-300 leading-relaxed">{project.data.solution}</p>
    </div>
  </section>

  <!-- The Results -->
  <section class="py-16 md:py-20">
    <div class="gs-reveal max-w-3xl mx-auto px-6 lg:px-8">
      <span class="block text-sm uppercase tracking-wider font-medium gradient-text mb-4">Τα Αποτελέσματα</span>
      <p class="text-lg text-neutral-700 leading-relaxed">{project.data.results}</p>
    </div>
  </section>

  <!-- Full-Width Image Gallery -->
  <section class="py-12">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="gs-stagger grid grid-cols-1 md:grid-cols-3 gap-6">
        {galleryImages.map((img, i) => (
          <div class="image-hover rounded-2xl">
            <img
              src={img}
              alt={`${project.data.title} — image ${i + 1}`}
              class="w-full h-auto aspect-video object-cover rounded-2xl"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  {project.data.testimonial && (
    <section class="bg-gradient-to-br from-purple-200 via-violet-200 to-purple-300 py-20 relative overflow-hidden">
      <div class="blob blob-purple -top-40 left-1/2 opacity-15"></div>

      <div class="relative gs-reveal max-w-3xl mx-auto px-6 lg:px-8 text-center">
        <div class="glass-dark p-10 md:p-14">
          <span class="block font-display text-6xl gradient-text leading-none select-none">&ldquo;</span>
          <p class="mt-4 text-xl italic text-neutral-300 leading-relaxed">
            {project.data.testimonial.quote}
          </p>
          <div class="mt-8">
            <span class="block text-white font-semibold">{project.data.testimonial.name}</span>
            <span class="block text-sm text-neutral-500 mt-1">{project.data.testimonial.role}</span>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Body Content -->
  <section class="py-16">
    <div class="max-w-3xl mx-auto px-6 lg:px-8
      [&>p]:mb-6 [&>p]:text-lg [&>p]:leading-relaxed [&>p]:text-neutral-700
      [&>h2]:font-display [&>h2]:text-2xl [&>h2]:font-bold [&>h2]:text-neutral-900 [&>h2]:mt-12 [&>h2]:mb-4
      [&>h3]:font-display [&>h3]:text-xl [&>h3]:font-semibold [&>h3]:text-neutral-900 [&>h3]:mt-10 [&>h3]:mb-3
      [&>ul]:list-disc [&>ul]:pl-6 [&>ul]:mb-6 [&>ul]:text-neutral-700 [&>ul]:leading-relaxed
      [&>ol]:list-decimal [&>ol]:pl-6 [&>ol]:mb-6 [&>ol]:text-neutral-700 [&>ol]:leading-relaxed
      [&>blockquote]:border-l-4 [&>blockquote]:border-primary-300 [&>blockquote]:pl-6 [&>blockquote]:italic [&>blockquote]:text-neutral-600 [&>blockquote]:my-8
    ">
      <Content />
    </div>
  </section>

  <!-- Next / Previous Navigation -->
  {(prevProject || nextProject) && (
    <section class="border-t border-neutral-200">
      <div class="max-w-4xl mx-auto px-6 lg:px-8 py-12">
        <div class="flex items-center justify-between">
          {prevProject ? (
            <a href={`/portfolio/${prevProject.id}`} class="group flex items-center gap-2 text-neutral-600 hover:text-primary-600 transition-colors duration-200">
              <svg class="w-4 h-4 transition-transform duration-200 group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
              </svg>
              <span class="text-sm">
                <span class="text-neutral-400">Προηγούμενο:</span>{' '}
                {prevProject.data.title}
              </span>
            </a>
          ) : (
            <div />
          )}
          {nextProject ? (
            <a href={`/portfolio/${nextProject.id}`} class="group flex items-center gap-2 text-neutral-600 hover:text-primary-600 transition-colors duration-200 text-right">
              <span class="text-sm">
                <span class="text-neutral-400">Επόμενο:</span>{' '}
                {nextProject.data.title}
              </span>
              <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          ) : (
            <div />
          )}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <CTASection heading="Έχετε ένα Project στο Μυαλό σας;" />
</BaseLayout>
