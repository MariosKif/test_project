---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import StatsBar from '../components/StatsBar.astro';
import CTASection from '../components/CTASection.astro';
import { getCollection } from 'astro:content';

const portfolioEntries = await getCollection('portfolio');
const featuredProjects = portfolioEntries.filter((p) => p.data.featured);

const projects = [
  {
    title: 'Luxe Beauty',
    category: 'E-Commerce & Branding',
    image: 'https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9?w=800&q=80',
    slug: 'luxe-beauty',
  },
  {
    title: 'FinTrack',
    category: 'SaaS Dashboard',
    image: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&q=80',
    slug: 'fintrack',
  },
  {
    title: 'Savora',
    category: 'Restaurant & Hospitality',
    image: 'https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=800&q=80',
    slug: 'savora',
  },
  {
    title: 'GreenLeaf',
    category: 'Corporate & Tech',
    image: 'https://images.unsplash.com/photo-1497366216548-37526070297c?w=800&q=80',
    slug: 'greenleaf',
  },
];
---

<BaseLayout
  title="210Designs — Web Design & Δημιουργικό Studio"
  description="Η 210Designs είναι ένα δημιουργικό studio που ειδικεύεται σε όμορφες ιστοσελίδες, δυνατά brands και ψηφιακές εμπειρίες που φέρνουν αποτελέσματα."
>
  <!-- ============================================================ -->
  <!-- HERO SECTION — DRAMATIC DARK                                  -->
  <!-- ============================================================ -->
  <section class="bg-gradient-to-br from-purple-200 via-violet-200 to-purple-300 relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1550745165-9bc0b252726f?w=1600&q=80"
        alt="Colorful retro technology setup representing creative digital design"
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
      />
    </div>

    <!-- Dark Overlay -->
    <div class="hero-overlay absolute inset-0"></div>

    <!-- Animated gradient shimmer -->
    <div class="hero-gradient absolute inset-0 opacity-30 mix-blend-overlay"></div>

    <!-- Decorative Blobs -->
    <div class="blob blob-purple" style="top: -100px; left: -150px; width: 600px; height: 600px; opacity: 0.3;"></div>
    <div class="blob blob-orange" style="bottom: -200px; right: -100px; width: 500px; height: 500px; opacity: 0.2;"></div>
    <div class="blob blob-blue" style="top: 40%; right: 10%; width: 300px; height: 300px; opacity: 0.15;"></div>

    <!-- Hero Content -->
    <div class="relative z-10 max-w-5xl mx-auto px-6 text-center hero-text-reveal">
      <h1 class="hero-line font-display text-5xl md:text-7xl lg:text-8xl font-bold leading-[1.05] mb-8">
        <span class="text-white">Σχεδιάζουμε</span><br />
        <span class="gradient-text">Ψηφιακές Εμπειρίες</span><br />
        <span class="text-white">που Μαγεύουν</span>
      </h1>

      <p class="hero-line text-lg md:text-xl text-neutral-300 max-w-2xl mx-auto mb-12 leading-relaxed">
        Η 210Designs είναι ένα δημιουργικό studio όπου η στρατηγική συναντά την τέχνη. Χτίζουμε
        όμορφες ιστοσελίδες, δυνατά brands και καθηλωτικά ψηφιακά προϊόντα που
        φέρνουν μετρήσιμα αποτελέσματα.
      </p>

      <div class="hero-line flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/portfolio"
          class="group inline-flex items-center px-8 py-4 text-base font-semibold text-white rounded-full transition-all duration-300 shadow-lg shadow-primary-500/25 hover:shadow-primary-500/40 hover:scale-105"
          style="background: linear-gradient(135deg, #6366f1, #8b5cf6, #7c3aed);"
        >
          Δείτε τη Δουλειά μας
          <svg class="ml-2 w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
        <a
          href="/contact"
          class="glass-dark inline-flex items-center px-8 py-4 text-base font-medium text-neutral-200 hover:text-white transition-all duration-300 hover:scale-105"
        >
          Επικοινωνήστε
        </a>
      </div>
    </div>

  </section>

  <!-- ============================================================ -->
  <!-- SERVICES SECTION — LIGHT WITH GRADIENT MESH                   -->
  <!-- ============================================================ -->
  <section class="gradient-bg relative py-24 md:py-32 overflow-hidden">
    <!-- Decorative Blob -->
    <div class="blob blob-purple" style="top: -150px; right: -200px; width: 500px; height: 500px; opacity: 0.2;"></div>
    <div class="blob blob-orange" style="bottom: -100px; left: -150px; width: 400px; height: 400px; opacity: 0.15;"></div>

    <div class="relative max-w-7xl mx-auto px-6">
      <div class="text-center mb-20">
        <p class="gs-reveal text-sm uppercase tracking-[0.2em] text-primary-500 font-semibold mb-4">Τι Κάνουμε</p>
        <h2 class="gs-reveal font-display text-4xl md:text-5xl lg:text-6xl font-bold text-neutral-900 mb-6">
          Δημιουργούμε <span class="gradient-text">Εξαιρετικές</span><br class="hidden md:block" /> Ψηφιακές Λύσεις
        </h2>
        <p class="gs-reveal text-lg text-neutral-500 max-w-2xl mx-auto leading-relaxed">
          Συνδυάζουμε δημιουργικότητα με τεχνολογία αιχμής για εμπειρίες
          που αφήνουν ανεξίτηλο αποτύπωμα
        </p>
      </div>

      <div class="gs-stagger grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Service Card 1 -->
        <div class="card-hover gradient-border p-8 bg-white">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-6" style="background: linear-gradient(135deg, #6366f1, #8b5cf6);">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-neutral-900 mb-3">Web Design</h3>
          <p class="text-neutral-500 leading-relaxed mb-6">
            Εντυπωσιακές, ανθρωποκεντρικές διεπαφές που μαγεύουν το κοινό σας. Δημιουργούμε responsive σχεδιασμούς που είναι όμορφοι σε κάθε συσκευή και προσφέρουν διαισθητικές εμπειρίες χρήσης.
          </p>
          <a href="/services" class="inline-flex items-center text-sm font-semibold text-primary-600 hover:text-primary-700 transition-colors group">
            Μάθετε περισσότερα
            <span class="ml-1 transition-transform duration-200 group-hover:translate-x-1">&rarr;</span>
          </a>
        </div>

        <!-- Service Card 2 -->
        <div class="card-hover gradient-border p-8 bg-white">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-6" style="background: linear-gradient(135deg, #8b5cf6, #ec4899);">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-neutral-900 mb-3">Web Development</h3>
          <p class="text-neutral-500 leading-relaxed mb-6">
            Full-stack ανάπτυξη με σύγχρονες τεχνολογίες. Από γρήγορες ιστοσελίδες marketing μέχρι σύνθετες web εφαρμογές, χτίζουμε αξιόπιστες λύσεις που κλιμακώνονται μαζί με την επιχείρησή σας.
          </p>
          <a href="/services" class="inline-flex items-center text-sm font-semibold text-primary-600 hover:text-primary-700 transition-colors group">
            Μάθετε περισσότερα
            <span class="ml-1 transition-transform duration-200 group-hover:translate-x-1">&rarr;</span>
          </a>
        </div>

        <!-- Service Card 3 -->
        <div class="card-hover gradient-border p-8 bg-white">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-6" style="background: linear-gradient(135deg, #ec4899, #f97316);">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-neutral-900 mb-3">SEO Βελτιστοποίηση</h3>
          <p class="text-neutral-500 leading-relaxed mb-6">
            Στρατηγικές SEO βασισμένες σε δεδομένα που ενισχύουν την ορατότητά σας. Από τεχνικά audits μέχρι βελτιστοποίηση λέξεων-κλειδιών, βοηθάμε την ιστοσελίδα σας να ανεβαίνει στις κατατάξεις.
          </p>
          <a href="/services" class="inline-flex items-center text-sm font-semibold text-primary-600 hover:text-primary-700 transition-colors group">
            Μάθετε περισσότερα
            <span class="ml-1 transition-transform duration-200 group-hover:translate-x-1">&rarr;</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- FEATURED WORK SECTION — DARK                                  -->
  <!-- ============================================================ -->
  <section class="bg-gradient-to-br from-purple-200 via-violet-200 to-purple-300 relative py-24 md:py-32 overflow-hidden">
    <!-- Decorative Blobs -->
    <div class="blob blob-purple" style="top: 10%; left: -100px; width: 400px; height: 400px; opacity: 0.15;"></div>
    <div class="blob blob-orange" style="bottom: 5%; right: -80px; width: 350px; height: 350px; opacity: 0.1;"></div>

    <div class="relative max-w-7xl mx-auto px-6">
      <div class="text-center mb-20">
        <p class="gs-reveal text-sm uppercase tracking-[0.2em] text-primary-400 font-semibold mb-4">Portfolio</p>
        <h2 class="gs-reveal font-display text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
          <span class="text-neutral-900">Επιλεγμένα</span> <span class="gradient-text">Έργα</span>
        </h2>
        <p class="gs-reveal text-lg text-neutral-700 max-w-2xl mx-auto">
          Μια επιμελημένη παρουσίαση των πιο σημαντικών μας έργων
        </p>
      </div>

      <div class="gs-stagger grid grid-cols-1 md:grid-cols-2 gap-8">
        {projects.map((project) => (
          <a href={`/portfolio/${project.slug}`} class="group block image-hover relative aspect-[16/10] rounded-2xl overflow-hidden">
            <img
              src={project.image}
              alt={project.title}
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
            />
            <!-- Default dark gradient at bottom -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
            <!-- Hover overlay -->
            <div class="absolute inset-0 bg-primary-900/70 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

            <!-- Content always visible at bottom -->
            <div class="absolute bottom-0 left-0 right-0 p-8 z-10">
              <span class="inline-block text-xs uppercase tracking-[0.15em] text-primary-300 font-semibold mb-2 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-2 group-hover:translate-y-0">{project.category}</span>
              <h3 class="text-2xl md:text-3xl font-bold text-white mb-3">{project.title}</h3>
              <span class="inline-flex items-center text-sm font-medium text-white/70 group-hover:text-white transition-all duration-300">
                Δείτε το Έργο
                <svg class="ml-2 w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>

      <div class="gs-reveal text-center mt-16">
        <a
          href="/portfolio"
          class="inline-flex items-center gap-2 px-8 py-4 text-base font-semibold text-white rounded-full transition-all duration-300 hover:scale-105 glass-dark"
        >
          Δείτε Όλα τα Έργα
          <span>&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- TESTIMONIALS SECTION — LIGHT WITH GRADIENT BG                 -->
  <!-- ============================================================ -->
  <section class="gradient-bg relative py-24 md:py-32 overflow-hidden">
    <!-- Decorative Blob -->
    <div class="blob blob-blue" style="top: -100px; left: 30%; width: 500px; height: 500px; opacity: 0.12;"></div>

    <div class="relative max-w-7xl mx-auto px-6">
      <div class="text-center mb-20">
        <p class="gs-reveal text-sm uppercase tracking-[0.2em] text-primary-500 font-semibold mb-4">Μαρτυρίες</p>
        <h2 class="gs-reveal font-display text-4xl md:text-5xl lg:text-6xl font-bold text-neutral-900 mb-6">
          Μας Εμπιστεύονται <span class="gradient-text">Κορυφαίοι του Κλάδου</span>
        </h2>
      </div>

      <div class="gs-stagger grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Testimonial 1 -->
        <div class="glass card-hover p-8 relative">
          <!-- Large decorative quote -->
          <span class="absolute -top-4 -left-2 font-display text-8xl gradient-text leading-none select-none opacity-30">&ldquo;</span>
          <div class="relative pt-6">
            <blockquote class="mb-8">
              <p class="text-lg text-neutral-700 leading-relaxed italic">
                "Η 210Designs μεταμόρφωσε πλήρως την online παρουσία μας. Η προσοχή στη λεπτομέρεια και το δημιουργικό όραμα ξεπέρασαν τις προσδοκίες μας."
              </p>
            </blockquote>
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full flex items-center justify-center text-white font-bold text-sm" style="background: linear-gradient(135deg, #6366f1, #8b5cf6);">JM</div>
              <div>
                <p class="font-semibold text-neutral-900">James Mitchell</p>
                <p class="text-sm text-neutral-500">CEO, Luxe Beauty Co.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Testimonial 2 -->
        <div class="glass card-hover p-8 relative">
          <span class="absolute -top-4 -left-2 font-display text-8xl gradient-text leading-none select-none opacity-30">&ldquo;</span>
          <div class="relative pt-6">
            <blockquote class="mb-8">
              <p class="text-lg text-neutral-700 leading-relaxed italic">
                "Η συνεργασία με την 210Designs ήταν καταλυτική. Δεν έφτιαξαν απλά ένα dashboard -- δημιούργησαν μια εμπειρία που οι χρήστες μας αγαπούν."
              </p>
            </blockquote>
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full flex items-center justify-center text-white font-bold text-sm" style="background: linear-gradient(135deg, #8b5cf6, #ec4899);">PS</div>
              <div>
                <p class="font-semibold text-neutral-900">Priya Sharma</p>
                <p class="text-sm text-neutral-500">CTO, FinTrack Inc.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Testimonial 3 -->
        <div class="glass card-hover p-8 relative">
          <span class="absolute -top-4 -left-2 font-display text-8xl gradient-text leading-none select-none opacity-30">&ldquo;</span>
          <div class="relative pt-6">
            <blockquote class="mb-8">
              <p class="text-lg text-neutral-700 leading-relaxed italic">
                "Το rebranding αποτύπωσε τέλεια την ουσία μας. Κάθε λεπτομέρεια, από το λογότυπο μέχρι την ιστοσελίδα, αφηγείται υπέροχα την ιστορία μας."
              </p>
            </blockquote>
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full flex items-center justify-center text-white font-bold text-sm" style="background: linear-gradient(135deg, #ec4899, #f97316);">MR</div>
              <div>
                <p class="font-semibold text-neutral-900">Marco Rossi</p>
                <p class="text-sm text-neutral-500">Owner, Savora Restaurant</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- CTA SECTION — ANIMATED GRADIENT                               -->
  <!-- ============================================================ -->
  <section class="hero-gradient relative py-24 md:py-32 overflow-hidden">
    <!-- Decorative Blobs -->
    <div class="blob" style="top: -100px; left: -100px; width: 400px; height: 400px; background: rgba(255,255,255,0.1); filter: blur(100px);"></div>
    <div class="blob" style="bottom: -100px; right: -100px; width: 400px; height: 400px; background: rgba(255,255,255,0.08); filter: blur(100px);"></div>

    <div class="relative max-w-4xl mx-auto px-6 text-center">
      <h2 class="gs-reveal font-display text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
        Ας Δημιουργήσουμε Κάτι<br />Εξαιρετικό Μαζί
      </h2>
      <p class="gs-reveal text-lg text-white/80 max-w-xl mx-auto leading-relaxed mb-10">
        Έτοιμοι να μεταμορφώσετε την ψηφιακή σας παρουσία; Ας συνεργαστούμε και ας δημιουργήσουμε
        κάτι που ο κόσμος δεν έχει ξαναδεί.
      </p>
      <div class="gs-reveal flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/contact"
          class="inline-flex items-center px-10 py-4 text-base font-semibold text-neutral-900 bg-white rounded-full transition-all duration-300 hover:scale-105 hover:shadow-2xl"
        >
          Ξεκινήστε ένα Project
          <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
        <a
          href="/portfolio"
          class="glass-dark inline-flex items-center px-8 py-4 text-base font-medium text-white hover:bg-white/10 transition-all duration-300"
        >
          Δείτε το Portfolio
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
