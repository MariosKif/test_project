---
interface Props {
  heading?: string;
  buttonText?: string;
  buttonHref?: string;
}

const {
  heading = "Ας Δημιουργήσουμε Κάτι Σπουδαίο",
  buttonText = 'Ξεκινήστε ένα Project',
  buttonHref = '/contact',
} = Astro.props;
---

<section class="relative overflow-hidden">
  <!-- Animated gradient background -->
  <div class="absolute inset-0 hero-gradient"></div>

  <!-- Decorative blobs for depth -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-32 -left-32 w-96 h-96 rounded-full bg-white/10 blur-3xl"></div>
    <div class="absolute -bottom-32 -right-32 w-96 h-96 rounded-full bg-white/10 blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-white/5 blur-3xl"></div>
  </div>

  <div class="relative max-w-4xl mx-auto px-6 lg:px-8 py-24 md:py-32 text-center">
    <h2 class="gs-reveal font-display text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight">
      {heading}
    </h2>

    <p class="gs-reveal mt-4 md:mt-6 text-lg text-white/80 max-w-xl mx-auto leading-relaxed">
      Έτοιμοι να μεταμορφώσετε την ψηφιακή σας παρουσία; Ας συνεργαστούμε και ας δημιουργήσουμε
      κάτι εξαιρετικό μαζί.
    </p>

    <div class="gs-reveal mt-10 md:mt-12">
      <a
        href={buttonHref}
        class="cta-btn inline-flex items-center px-10 py-4 text-base font-semibold text-neutral-900 bg-white rounded-full transition-all duration-300 hover:shadow-2xl hover:shadow-white/20 hover:scale-105"
      >
        {buttonText}
        <svg
          class="ml-2 w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
