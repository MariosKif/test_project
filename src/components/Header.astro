---
const navLinks = [
  { label: 'Σχετικά', href: '/about' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Τιμές', href: '/pricing' },
  { label: 'Επικοινωνία', href: '/contact' },
];

const serviceLinks = [
  { label: 'Web Design', href: '/services/web-design' },
  { label: 'Web Development', href: '/services/web-development' },
  { label: 'SEO', href: '/services/seo' },
  { label: 'Branding', href: '/services/branding' },
];
---

<header
  class="navbar fixed top-0 left-0 right-0 z-50 transition-all duration-500 bg-white/70 backdrop-blur-xl border-b border-transparent"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-18">
      <!-- Logo -->
      <a href="/" class="flex-shrink-0 group">
        <span class="font-display text-2xl md:text-3xl tracking-tight">
          <span class="font-bold gradient-text">210</span><span class="font-light text-neutral-700">Designs</span>
        </span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-8">
        <a
          href="/about"
          class="nav-link relative text-sm tracking-wide text-neutral-600 hover:text-neutral-900 transition-colors duration-300 py-1"
        >
          Σχετικά
        </a>

        <!-- Services Dropdown -->
        <div class="services-dropdown relative">
          <a
            href="/services"
            class="nav-link relative text-sm tracking-wide text-neutral-600 hover:text-neutral-900 transition-colors duration-300 py-1 inline-flex items-center gap-1"
          >
            Υπηρεσίες
            <svg class="w-3.5 h-3.5 transition-transform duration-200 dropdown-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </a>

          <!-- Dropdown Menu -->
          <div class="dropdown-menu absolute top-full left-1/2 -translate-x-1/2 pt-3 opacity-0 invisible transition-all duration-300">
            <div class="bg-white rounded-xl border border-neutral-200 shadow-xl shadow-neutral-200/50 py-2 min-w-[200px]">
              {serviceLinks.map((link) => (
                <a
                  href={link.href}
                  class="block px-5 py-2.5 text-sm text-neutral-600 hover:text-primary-600 hover:bg-primary-50 transition-colors duration-200"
                >
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        </div>

        <a
          href="/portfolio"
          class="nav-link relative text-sm tracking-wide text-neutral-600 hover:text-neutral-900 transition-colors duration-300 py-1"
        >
          Portfolio
        </a>
        <a
          href="/pricing"
          class="nav-link relative text-sm tracking-wide text-neutral-600 hover:text-neutral-900 transition-colors duration-300 py-1"
        >
          Τιμές
        </a>
        <a
          href="/contact"
          class="nav-link relative text-sm tracking-wide text-neutral-600 hover:text-neutral-900 transition-colors duration-300 py-1"
        >
          Επικοινωνία
        </a>
      </nav>

      <!-- CTA Button (Desktop) -->
      <div class="hidden lg:flex items-center">
        <a
          href="/contact"
          class="nav-cta inline-flex items-center px-6 py-2.5 text-sm font-medium text-white rounded-full transition-all duration-300 bg-gradient-to-r from-primary-600 to-violet-500 hover:shadow-lg hover:shadow-primary-500/30 hover:scale-105"
        >
          Ξεκινήστε ένα Project
        </a>
      </div>

      <!-- Mobile Hamburger -->
      <button
        id="mobile-menu-toggle"
        class="lg:hidden flex flex-col items-center justify-center w-10 h-10 gap-1.5 group"
        aria-label="Άνοιγμα μενού"
      >
        <span class="block w-6 h-0.5 rounded-full bg-gradient-to-r from-primary-600 to-violet-500 transition-all duration-300 group-hover:w-5"></span>
        <span class="block w-5 h-0.5 rounded-full bg-gradient-to-r from-primary-600 to-violet-500 transition-all duration-300 group-hover:w-6"></span>
        <span class="block w-4 h-0.5 rounded-full bg-gradient-to-r from-primary-600 to-violet-500 transition-all duration-300 group-hover:w-6"></span>
      </button>
    </div>
  </div>
</header>

<!-- Spacer to offset fixed header -->
<div class="h-18"></div>

<style>
  /* Nav link hover underline expanding from center */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 50%;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, #6366f1, #8b5cf6);
    border-radius: 1px;
    transition: width 0.3s cubic-bezier(0.22, 1, 0.36, 1), left 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .nav-link:hover::after {
    width: 100%;
    left: 0;
  }

  /* Dropdown */
  .services-dropdown:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
  }

  .services-dropdown:hover .dropdown-arrow {
    transform: rotate(180deg);
  }

  /* Scrolled state */
  .navbar-scrolled {
    background-color: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(24px) saturate(200%);
    -webkit-backdrop-filter: blur(24px) saturate(200%);
    border-bottom: 1px solid transparent;
    border-image: linear-gradient(90deg, transparent, rgba(99, 102, 241, 0.3), rgba(139, 92, 246, 0.3), transparent) 1;
    box-shadow: 0 4px 30px -8px rgba(99, 102, 241, 0.1);
  }
</style>

<script>
  const menuToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  if (menuToggle && mobileMenu) {
    menuToggle.addEventListener('click', () => {
      mobileMenu.classList.remove('translate-x-full');
      mobileMenu.classList.add('translate-x-0');
      document.body.style.overflow = 'hidden';
    });
  }

  // Scroll detection
  const navbar = document.querySelector('.navbar');
  if (navbar) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 20) {
        navbar.classList.add('navbar-scrolled');
      } else {
        navbar.classList.remove('navbar-scrolled');
      }
    });
  }
</script>
