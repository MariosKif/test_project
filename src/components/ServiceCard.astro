---
interface Props {
  icon: string;
  title: string;
  description: string;
  href: string;
}

const { icon, title, description, href } = Astro.props;
---

<div class="gs-reveal service-card group card-hover gradient-border rounded-2xl bg-white p-8 border border-neutral-100 transition-all duration-400">
  <!-- Icon container -->
  <div class="flex items-center justify-center w-12 h-12 rounded-full bg-gradient-to-br from-primary-600 to-violet-500 text-white text-xl mb-5 shadow-lg shadow-primary-500/20">
    {icon}
  </div>

  <h3 class="text-lg font-semibold text-neutral-800 mb-3">{title}</h3>
  <p class="text-neutral-500 text-sm leading-relaxed mb-5">{description}</p>
  <a
    href={href}
    class="inline-flex items-center text-sm font-medium text-primary-600 transition-colors duration-300 hover:text-violet-500"
  >
    Learn more
    <svg class="ml-1.5 w-4 h-4 transition-transform duration-300 group-hover:translate-x-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
    </svg>
  </a>
</div>

<style>
  .service-card {
    position: relative;
  }

  /* Hide gradient border by default, show on hover */
  .service-card::before {
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .service-card:hover::before {
    opacity: 1;
  }

  .service-card:hover {
    box-shadow:
      0 20px 40px -12px rgba(99, 102, 241, 0.2),
      0 0 0 1px rgba(139, 92, 246, 0.1);
  }
</style>
