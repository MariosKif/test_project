---
const companyLinks = [
  { label: 'Σχετικά', href: '/about' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Τιμές', href: '/pricing' },
  { label: 'Επικοινωνία', href: '/contact' },
];

const serviceLinks = [
  { label: 'Web Design', href: '/services/web-design' },
  { label: 'Web Development', href: '/services/web-development' },
  { label: 'SEO', href: '/services/seo' },
  { label: 'Branding', href: '/services/branding' },
];
---

<footer class="bg-gradient-to-br from-purple-700 via-violet-700 to-purple-900 relative overflow-hidden">
  <!-- Gradient line at top -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary-500 to-transparent"></div>

  <!-- Subtle blob decoration -->
  <div class="blob blob-purple" style="top: -200px; right: -150px; width: 500px; height: 500px; opacity: 0.08;"></div>

  <!-- Top Section -->
  <div class="relative max-w-7xl mx-auto px-6 lg:px-8 py-16 lg:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
      <!-- Col 1: Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-4">
          <span class="font-display text-xl tracking-tight">
            <span class="font-bold gradient-text">210</span><span class="font-light text-white">Designs</span>
          </span>
        </a>
        <p class="text-sm text-purple-200 leading-relaxed mb-6 max-w-xs">
          Δημιουργούμε premium ψηφιακές εμπειρίες για brands που τολμούν να ξεχωρίσουν.
        </p>
        <!-- Social Links -->
        <div class="flex items-center gap-3">
          <!-- Twitter/X -->
          <a
            href="https://x.com/210designs"
            target="_blank"
            rel="noopener noreferrer"
            class="social-icon flex items-center justify-center w-10 h-10 rounded-xl glass-dark text-purple-200 hover:text-white transition-all duration-300"
            aria-label="Twitter"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path>
            </svg>
          </a>
          <!-- Instagram -->
          <a
            href="https://instagram.com/210designs"
            target="_blank"
            rel="noopener noreferrer"
            class="social-icon flex items-center justify-center w-10 h-10 rounded-xl glass-dark text-purple-200 hover:text-white transition-all duration-300"
            aria-label="Instagram"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Col 2: Company -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">
          Εταιρεία
        </h4>
        <ul class="space-y-3">
          {
            companyLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-purple-200 hover:text-white transition-colors duration-300"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Col 3: Services -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">
          Υπηρεσίες
        </h4>
        <ul class="space-y-3">
          {
            serviceLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-purple-200 hover:text-white transition-colors duration-300"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Col 4: Newsletter -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">
          Ενημερωτικό Δελτίο
        </h4>
        <p class="text-sm text-purple-200 leading-relaxed mb-4">
          Λάβετε συμβουλές σχεδιασμού και τάσεις του κλάδου στο email σας.
        </p>
        <form id="newsletter-form" class="flex gap-2">
          <input
            type="email"
            placeholder="your@email.com"
            required
            class="flex-1 min-w-0 px-4 py-2.5 text-sm text-white glass-dark rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent placeholder:text-purple-300"
          />
          <button
            type="submit"
            class="px-5 py-2.5 text-sm font-medium text-white rounded-lg transition-all duration-300 flex-shrink-0 bg-gradient-to-r from-primary-600 to-violet-500 hover:shadow-lg hover:shadow-primary-500/25"
          >
            Εγγραφή
          </button>
        </form>
        <p id="newsletter-success" class="hidden mt-3 text-sm text-green-300">Ευχαριστούμε για την εγγραφή!</p>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="relative border-t border-white/20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-purple-300">
        &copy; 2026 210Designs. Όλα τα δικαιώματα κατοχυρωμένα.
      </p>
      <div class="flex items-center gap-6">
        <a
          href="/privacy"
          class="text-sm text-purple-300 hover:text-white transition-colors duration-300"
        >
          Πολιτική Απορρήτου
        </a>
        <a
          href="/terms"
          class="text-sm text-purple-300 hover:text-white transition-colors duration-300"
        >
          Όροι Χρήσης
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .social-icon:hover {
    border-color: rgba(99, 102, 241, 0.5);
    background: rgba(99, 102, 241, 0.1);
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.15);
  }
</style>

<script>
  const newsletterForm = document.getElementById('newsletter-form');
  const newsletterSuccess = document.getElementById('newsletter-success');

  if (newsletterForm && newsletterSuccess) {
    newsletterForm.addEventListener('submit', (e) => {
      e.preventDefault();
      newsletterForm.reset();
      newsletterSuccess.classList.remove('hidden');
      setTimeout(() => newsletterSuccess.classList.add('hidden'), 4000);
    });
  }
</script>
