---
interface Props {
  image?: string;
  title: string;
  category: string;
  slug: string;
}

const { image, title, category, slug } = Astro.props;
---

<a href={`/portfolio/${slug}`} class="project-card group block rounded-2xl overflow-hidden card-hover image-hover relative">
  <div class="relative aspect-4/3">
    <!-- Gradient placeholder or real image -->
    {image ? (
      <img
        src={image}
        alt={title}
        class="absolute inset-0 w-full h-full object-cover transition-transform duration-600"
        loading="lazy"
      />
    ) : (
      <div class="absolute inset-0 bg-gradient-to-br from-primary-600 via-violet-500 to-primary-800 flex items-center justify-center">
        <span class="text-white/30 text-lg font-medium">{title}</span>
      </div>
    )}

    <!-- Always-visible bottom gradient with title -->
    <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-black/80 via-black/40 to-transparent flex items-end p-6 transition-opacity duration-300 group-hover:opacity-0">
      <h3 class="text-white text-lg font-semibold">{title}</h3>
    </div>

    <!-- Hover full overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/60 to-black/30 flex flex-col items-center justify-center text-center p-6 opacity-0 transition-all duration-400 group-hover:opacity-100">
      <span class="text-xs uppercase tracking-widest text-primary-300 mb-3 font-medium">{category}</span>
      <h3 class="text-white text-xl font-bold mb-4">{title}</h3>
      <span class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 text-white transition-transform duration-300 group-hover:scale-110">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </span>
    </div>
  </div>
</a>

<style>
  .project-card {
    position: relative;
  }

  .project-card::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 1rem;
    padding: 1px;
    background: linear-gradient(135deg, transparent, transparent);
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    z-index: 10;
    transition: background 0.4s ease;
  }

  .project-card:hover::before {
    background: linear-gradient(135deg, #6366f1, #8b5cf6, #ec4899);
  }
</style>
