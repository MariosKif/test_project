---
interface Props {
  name: string;
  price: string;
  description?: string;
  features: string[];
  highlighted?: boolean;
  buttonText?: string;
  period?: string;
  hosting?: string;
}

const { name, price, description, features, highlighted = false, buttonText = "Ξεκινήστε", period, hosting } = Astro.props;
---

<div class={`relative rounded-2xl bg-white p-8 h-full flex flex-col border ${highlighted ? 'border-[#7c3aed]' : 'border-neutral-200'}`}>
  <!-- Popular badge -->
  {highlighted && (
    <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
      <span class="inline-block text-white text-xs font-bold uppercase tracking-wider rounded-md px-4 py-1.5 bg-[#7c3aed]">
        ΔΗΜΟΦΙΛΕΣ
      </span>
    </div>
  )}

  <!-- Icon -->
  <div class="flex justify-center mb-5">
    <div class="w-10 h-10 rounded-lg border border-neutral-200 flex items-center justify-center">
      <svg class="w-5 h-5 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
      </svg>
    </div>
  </div>

  <!-- Plan name -->
  <div class="text-center mb-6">
    <h3 class="text-lg font-semibold text-neutral-900 mb-4">{name}</h3>
    <div class="mb-2">
      {price.includes('€') ? (
        <>
          <span class="text-5xl font-bold text-neutral-900">{price.replace('€', '')}</span>
          <span class="text-base text-neutral-500 ml-1">€{period ? period : ''} +ΦΠΑ</span>
        </>
      ) : (
        <span class="text-4xl font-bold text-neutral-900">{price} <span class="text-xl font-normal text-neutral-500">Τιμή</span></span>
      )}
    </div>
    {hosting && (
      <p class="text-sm text-[#7c3aed] font-medium mt-2">{hosting}</p>
    )}
    {description && (
      <p class="text-sm text-neutral-500 mt-3">{description}</p>
    )}
  </div>

  <!-- Features header -->
  {features.length > 0 && (
    <div class="mb-4">
      <p class="text-sm font-semibold text-neutral-900">Τι θα αποκτήσετε</p>
    </div>
  )}

  <!-- Features list -->
  <ul class="space-y-3 mb-8 flex-grow">
    {features.map((feature) => (
      <li class="flex items-start gap-3 text-sm text-neutral-600">
        <svg class="w-5 h-5 text-[#7c3aed] flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
        </svg>
        <span>{feature}</span>
      </li>
    ))}
  </ul>

  <!-- CTA button -->
  <a
    href="/contact"
    class="block w-full text-center py-3.5 px-6 rounded-xl font-medium text-sm transition-all duration-300 bg-[#7c3aed] text-white hover:bg-[#6d28d9] hover:shadow-lg"
  >
    {buttonText}
  </a>
</div>
