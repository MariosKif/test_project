---
interface Props {
  image?: string;
  title: string;
  excerpt: string;
  date: string;
  category: string;
  slug: string;
}

const { image, title, excerpt, date, category, slug } = Astro.props;
---

<a href={`/blog/${slug}`} class="group block rounded-2xl overflow-hidden bg-white border border-neutral-100 card-hover image-hover">
  <!-- Image area -->
  <div class="relative aspect-video overflow-hidden">
    {image ? (
      <img
        src={image}
        alt={title}
        class="absolute inset-0 w-full h-full object-cover transition-transform duration-600"
        loading="lazy"
      />
    ) : (
      <div class="absolute inset-0 bg-gradient-to-br from-primary-500 via-violet-500 to-primary-700 flex items-center justify-center">
        <span class="text-white/20 text-sm font-medium">{title}</span>
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="p-6">
    <!-- Category badge -->
    <span class="inline-block text-xs font-semibold uppercase tracking-wider text-white rounded-full px-3 py-1 mb-4 bg-gradient-to-r from-primary-600 to-violet-500">
      {category}
    </span>

    <h3 class="font-semibold text-lg text-neutral-800 mb-2 group-hover:text-primary-600 transition-colors duration-300 leading-snug">
      {title}
    </h3>

    <p class="text-neutral-500 text-sm leading-relaxed line-clamp-2 mb-4">
      {excerpt}
    </p>

    <time class="text-xs text-neutral-400 font-medium">{date}</time>
  </div>
</a>

<style>
  .group:hover {
    box-shadow:
      0 20px 40px -12px rgba(99, 102, 241, 0.15),
      0 0 0 1px rgba(139, 92, 246, 0.08);
  }
</style>
